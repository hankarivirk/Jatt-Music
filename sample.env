# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#   🎵 JATT MUSIC BOT — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# From my.telegram.org/apps
API_ID=
API_HASH=

# From @BotFather on Telegram
BOT_TOKEN=

# Your Telegram user/channel ID for bot logs
LOGGER_ID=

# MongoDB connection URL (cloud.mongodb.com)
MONGO_URL=

# Your Telegram User ID (bot owner)
OWNER_ID=

# Pyrogram user session string (from @StringFatherBot)
SESSION=

# Optional: extra userbot sessions
SESSION2=
SESSION3=

# Optional settings (defaults shown)
DURATION_LIMIT=60
QUEUE_LIMIT=20
PLAYLIST_LIMIT=20
AUTO_LEAVE=False
AUTO_END=False
THUMB_GEN=True
VIDEO_PLAY=True
LANG_CODE=en

# Optional: Your support group & channel links
SUPPORT_CHAT=https://t.me/JattMusicSupport
SUPPORT_CHANNEL=https://t.me/JattMusicUpdates
